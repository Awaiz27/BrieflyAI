# ═══════════════════════════════════════════════════════════════════════════
# BrieflyAI - Unified Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════
# This single .env file is used by both backend and frontend services.
# Copy to .env and update values for your environment.
# DO NOT commit .env to version control.

# ── Application ──────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=9001
DEBUG=false
LOG_LEVEL=INFO

# ── Frontend / Next.js ───────────────────────────────────────────────────
# Public API URL accessible from browser (used in frontend code)
NEXT_PUBLIC_API_URL=http://localhost:9001
# Show debug score on paper cards (development only)
NEXT_PUBLIC_SHOW_DEBUG_SCORE=false

# ── PostgreSQL ───────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_SCHEMA=BrieflyAI
POSTGRES_API_POOL_SIZE=40
POSTGRES_API_POOL_OVERFLOW=10

# ── JWT ──────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_EXPIRY_HOURS=72

# ── Ollama / LLM Providers ───────────────────────────────────────────────
# Base URL for local Ollama instance
MODEL_BASE_URL=http://localhost:11434
# Embedding model for RAG (always uses Ollama)
EMBEDDER_MODEL_NAME=qwen3-embedding:0.6b-fp16
# Default LLM model (used when LLM_PROVIDER=ollama)
LLM_MODEL_NAME=qwen3:0.6b-q4_K_M

# ── LLM Provider Selection ───────────────────────────────────────────────
# Options: ollama (default), groq
# Set to 'groq' to use Groq cloud API for chat responses
LLM_PROVIDER=ollama
# Groq API key (required if LLM_PROVIDER=groq)
GROQ_API_KEY=your-groq-api-key-here
# Groq model name (used when LLM_PROVIDER=groq)
GROQ_LLM_MODEL_NAME=openai/gpt-oss-120b

# ── arXiv Fetcher ────────────────────────────────────────────────────────
# Category filter for arXiv papers (e.g., cs.AI, cs.LG, cs.*, etc.)
PAPER_API_CATEGORY=cs.*
# Maximum papers to fetch per query
PAPER_API_MAX_RESULTS=100
# Default time window for fetching papers (e.g., 1d, 4d, 1w)
PAPER_API_DEFAULT_WINDOW=4d
# arXiv API endpoint
PAPER_API_BASE_URL=https://export.arxiv.org/api/query
# HTTP timeout for paper API requests (seconds)
PAPER_API_HTTP_TIMEOUT=30

# ── Celery / Task Queue ──────────────────────────────────────────────────
# RabbitMQ broker URL
CELERY_BROKER_URL=amqp://guest:guest@localhost:5672//
# Redis result backend
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ── RabbitMQ (for docker-compose) ────────────────────────────────────────
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# ── Redis ────────────────────────────────────────────────────────────────
# Redis host and port (for Celery result backend, caching, etc.)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
